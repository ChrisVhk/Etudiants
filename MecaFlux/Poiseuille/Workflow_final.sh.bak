#!/bin/bash

################################################################################
#        WORKFLOW FINAL — Hagen-Poiseuille OpenFOAM 2412
#
#  Usage:
#    ./Workflow_final.sh          → menu interactif
#    ./Workflow_final.sh all      → toutes les étapes
#    ./Workflow_final.sh 0        → install dépendances (venv)
#    ./Workflow_final.sh 1        → master_setup_V2.sh
#    ./Workflow_final.sh 2        → run_all_cases_V2.sh
#    ./Workflow_final.sh 3        → analyze_results.py
#    ./Workflow_final.sh 4        → plot_results.py
#    ./Workflow_final.sh 5        → compare_cases.py
#    ./Workflow_final.sh 6        → extract_profile.py
#    ./Workflow_final.sh 7        → convergence_check.py
#    ./Workflow_final.sh 8        → ParaView
#    ./Workflow_final.sh 3-7      → étapes 3 à 7
#    ./Workflow_final.sh 1,2,5    → étapes 1, 2 et 5
################################################################################

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/venv"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

print_step()  { echo -e "\n${BLUE}${BOLD}═══ $1 ═══${NC}"; }
print_ok()    { echo -e "${GREEN}✅ $1${NC}"; }
print_info()  { echo -e "${YELLOW}ℹ️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }

# ─────────────────────────────────────────────────────────────────────────────
# DÉFINITION DES ÉTAPES
# ─────────────────────────────────────────────────────────────────────────────

step0() {
    print_step "0 — Installation dépendances Python (venv)"

    # Test réel : essayer de créer un venv temporaire
    if ! python3 -m venv /tmp/test_venv_$$ &>/dev/null 2>&1; then
        rm -rf /tmp/test_venv_$$
        print_error "python3-venv manquant !"
        print_info "Installation en cours (sudo requis)..."
        sudo apt install -y python3.12-venv || {
            print_error "Impossible d'installer python3.12-venv"
            exit 1
        }
        print_ok "python3.12-venv installé"
    else
        rm -rf /tmp/test_venv_$$
    fi

    # Supprimer un venv cassé si présent
    if [ -d "$VENV_DIR" ] && [ ! -f "$VENV_DIR/bin/activate" ]; then
        print_info "venv incomplet détecté — suppression..."
        rm -rf "$VENV_DIR"
    fi

    # Créer le venv si absent
    if [ ! -d "$VENV_DIR" ]; then
        print_info "Création du venv..."
        python3 -m venv "$VENV_DIR" || {
            print_error "Échec création venv"
            exit 1
        }
        print_ok "venv créé : $VENV_DIR"
    else
        print_info "venv déjà existant"
    fi

    source "$VENV_DIR/bin/activate"
    pip install -q --upgrade pip
    pip install -q -r "$SCRIPT_DIR/scripts/requirements.txt"
    print_ok "Dépendances installées"
}


step1() {
    print_step "1 — Création des cas (master_setup_V2.sh)"
    bash "$SCRIPT_DIR/master_setup_V2.sh"
    print_ok "Cas créés"
}

step2() {
    print_step "2 — Simulations OpenFOAM (run_all_cases_V2.sh)"
    bash "$SCRIPT_DIR/run_all_cases_V2.sh"
    print_ok "Simulations terminées"
}

step3() {
    print_step "3 — Analyse des résultats"
    _activate_venv
    python3 "$SCRIPT_DIR/scripts/analyze_results.py"
    print_ok "Analyse OK"
}

step4() {
    print_step "4 — Graphiques"
    _activate_venv
    python3 "$SCRIPT_DIR/scripts/plot_results.py"
    print_ok "Graphiques générés"
}

step5() {
    print_step "5 — Comparaison des cas"
    _activate_venv
    python3 "$SCRIPT_DIR/scripts/compare_cases.py"
    print_ok "Comparaison OK"
}

step6() {
    print_step "6 — Profils de vitesse extraits"
    _activate_venv
    python3 "$SCRIPT_DIR/scripts/extract_profile.py"
    print_ok "Profils OK"
}

step7() {
    print_step "7 — Vérification convergence"
    _activate_venv
    python3 "$SCRIPT_DIR/scripts/convergence_check.py"
    print_ok "Convergence OK"
}

step8() {
    print_step "8 — Visualisation ParaView"
    if command -v paraview &>/dev/null; then
        paraview "$SCRIPT_DIR/case0/VTK/case0.vtm.series" &
        print_ok "ParaView lancé (PID $!)"
    else
        print_error "ParaView non trouvé"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# HELPER : activer le venv pour les étapes Python
# ─────────────────────────────────────────────────────────────────────────────

_activate_venv() {
    if [ -f "$VENV_DIR/bin/activate" ]; then
        source "$VENV_DIR/bin/activate"
    else
        print_error "venv absent — lancez d'abord : ./Workflow_final.sh 0"
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# MENU INTERACTIF
# ─────────────────────────────────────────────────────────────────────────────

show_menu() {
    echo -e "\n${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║   WORKFLOW Hagen-Poiseuille OpenFOAM     ║${NC}"
    echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
    echo -e "  ${BOLD}0${NC}  — Install dépendances Python (venv)"
    echo -e "  ${BOLD}1${NC}  — Créer les cas (master_setup_V2)"
    echo -e "  ${BOLD}2${NC}  — Lancer simulations (run_all_cases_V2)"
    echo -e "  ${BOLD}3${NC}  — Analyser résultats"
    echo -e "  ${BOLD}4${NC}  — Générer graphiques"
    echo -e "  ${BOLD}5${NC}  — Comparer les cas"
    echo -e "  ${BOLD}6${NC}  — Extraire profils de vitesse"
    echo -e "  ${BOLD}7${NC}  — Vérifier convergence"
    echo -e "  ${BOLD}8${NC}  — Ouvrir ParaView"
    echo -e "  ${BOLD}all${NC} — Toutes les étapes (0→8)"
    echo -e "  ${BOLD}q${NC}  — Quitter"
    echo ""
    echo -e "  Exemples: ${YELLOW}3-7${NC}  ou  ${YELLOW}1,2,5${NC}"
    echo -ne "\n${BOLD}Votre choix : ${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────
# EXÉCUTION D'UNE ÉTAPE
# ─────────────────────────────────────────────────────────────────────────────

run_step() {
    case "$1" in
        0) step0 ;;
        1) step1 ;;
        2) step2 ;;
        3) step3 ;;
        4) step4 ;;
        5) step5 ;;
        6) step6 ;;
        7) step7 ;;
        8) step8 ;;
        *) print_error "Étape inconnue : $1" ;;
    esac
}

parse_and_run() {
    local arg="$1"

    # "all"
    if [ "$arg" = "all" ]; then
        for i in 0 1 2 3 4 5 6 7 8; do run_step $i; done
        return
    fi

    # "3-7" (plage)
    if [[ "$arg" =~ ^([0-8])-([0-8])$ ]]; then
        local start="${BASH_REMATCH[1]}"
        local end="${BASH_REMATCH[2]}"
        for (( i=start; i<=end; i++ )); do run_step $i; done
        return
    fi

    # "1,2,5" (liste)
    if [[ "$arg" =~ , ]]; then
        IFS=',' read -ra steps <<< "$arg"
        for s in "${steps[@]}"; do run_step "$s"; done
        return
    fi

    # étape unique
    run_step "$arg"
}

# ─────────────────────────────────────────────────────────────────────────────
# POINT D'ENTRÉE
# ─────────────────────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
    # Mode interactif
    while true; do
        show_menu
        read -r choice
        [ "$choice" = "q" ] && echo -e "${GREEN}Au revoir !${NC}" && exit 0
        parse_and_run "$choice"
        echo -e "\n${CYAN}Appuyez sur Entrée pour continuer...${NC}"
        read -r
    done
else
    # Mode argument direct
    parse_and_run "$1"
fi
